{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockMantleInvoke",
      "Effect": "Allow",
      "Action": [
        "bedrock-mantle:InvokeModel",
        "bedrock-mantle:InvokeModelWithResponseStream"
      ],
      "Resource": "*"
    },
    {
      "Sid": "BedrockClassicInvokeFallback",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": [
        "arn:aws:bedrock:*::foundation-model/anthropic.*",
        "arn:aws:bedrock:*:*:inference-profile/*anthropic.*"
      ]
    }
  ]
}
