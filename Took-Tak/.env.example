# 이 파일을 .env 로 복사해서 채우세요.  cp .env.example .env
# .env 는 .gitignore 에 있습니다. 실제 값을 커밋하지 마세요.

# 서버
PORT=4000

# PostgreSQL (DB 전용 EC2, private subnet)
DB_HOST=your-db-ec2-private-ip
DB_PORT=5432
DB_NAME=tooktak
DB_USER=tooktak
DB_PASSWORD=

# JWT 서명 키
# 생성: openssl rand -hex 32
JWT_SECRET=

# 관리자 등록·로그인 초대 코드
# 비밀번호 인증이 없으므로 관리자 권한을 막는 유일한 값입니다. 반드시 채우세요.
ADMIN_SIGNUP_CODE=

# Amazon Bedrock (AI 신고 분류)
# 자격증명은 EC2 인스턴스 프로파일(IAM 역할)에서 자동으로 옵니다. 액세스 키를 넣지 마세요.
#
# ⚠ 서울(ap-northeast-2)에는 Bedrock Mantle 엔드포인트가 없습니다. (2026-07-23 실측)
#   bedrock-mantle.ap-northeast-2.api.aws 는 DNS 조회 자체가 실패합니다.
#   ap-northeast-3(오사카)도 없습니다. 한국에서 가장 가까운 곳은 도쿄입니다.
#   확인된 리전: us-east-1, us-east-2, us-west-2, eu-west-1, eu-central-1,
#                ap-northeast-1, ap-southeast-1, ap-southeast-2, ap-south-1
#   ※ 서울로 두면 "Connection error." 만 뜨고 원인이 드러나지 않습니다.
AWS_REGION=ap-northeast-1
# 미설정이면 AI 분류를 건너뛰고 신고만 접수됩니다(서버는 정상 기동).
# eu-west-1 에서 실제 호출 검증 완료 (2026-07-23). 리전별 모델 액세스는 따로 승인해야 합니다.
BEDROCK_MODEL_ID=anthropic.claude-opus-4-8

# 공개 업로드 이미지 베이스 URL. 비우면 요청의 host 를 사용합니다.
# 예: PUBLIC_BASE_URL=http://localhost:4000
PUBLIC_BASE_URL=

# CORS 허용 오리진 (쉼표로 여러 개). 비우면 전체 허용 — 로컬 개발에서만 비워두세요.
# 예: CORS_ORIGIN=http://frontend-public-ip,https://tooktak.example.com
CORS_ORIGIN=
